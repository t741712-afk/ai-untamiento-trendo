# =============================================================================
# AI-untamiento de Trendo — Variables de entorno
# Copia este fichero como .env y rellena los valores antes de desplegar.
# =============================================================================

# --- OpenAI -------------------------------------------------------------------
# API key de OpenAI para el chatbot (modelo gpt-4o-mini)
OPENAI_API_KEY=

# --- Trend Micro AI Guard -----------------------------------------------------
# API key de Vision One (token de autenticación)
TREND_API_KEY=

# Endpoint de AI Guard. Cambia "eu" por "us", "ap", "au", "in", "sg"
# según la región de tu tenant de Vision One.
TREND_AI_URL=https://api.eu.xdr.trendmicro.com/v3.0/aiSecurity/applyGuardrails

# Nombre de la aplicación registrada en Vision One AI Security
TREND_AI_APP_NAME=ai-untamiento-trendo

# --- Trend Micro File Security -------------------------------------------------
# API key de Vision One para File Security (puede ser la misma que TREND_API_KEY)
FILE_SECURITY_API_KEY=

# Host del scanner cloud de Vision One File Security.
# Encuéntralo en: Vision One console → File Security → Scanner settings
# Formato típico por región:
#   US  → antimalware.us-1.cloudone.trendmicro.com
#   EU  → antimalware.eu-1.cloudone.trendmicro.com
#   AP  → antimalware.ap-1.cloudone.trendmicro.com
FILE_SECURITY_HOST=

# --- Puertos del host ----------------------------------------------------------
BACKEND_PORT=9000
FRONTEND_PORT=80

# --- Backend internals --------------------------------------------------------
UPLOAD_DIR=/data/uploads
