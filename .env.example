# =============================================================================
# AI-untamiento de Trendo — Variables de entorno
# Copia este fichero como .env y rellena los valores antes de desplegar.
# =============================================================================

# --- Groq (LLM gratuito, modelo llama-3.3-70b-versatile) ---------------------
# Obtén tu key gratuita en: console.groq.com → API Keys
GROQ_API_KEY=

# --- Trend Micro AI Guard -----------------------------------------------------
TREND_API_KEY=

# Endpoint de AI Guard según la región de tu tenant de Vision One.
# eu → api.eu.xdr.trendmicro.com  |  us → api.xdr.trendmicro.com
TREND_AI_URL=https://api.eu.xdr.trendmicro.com/v3.0/aiSecurity/applyGuardrails

TREND_AI_APP_NAME=ai-untamiento-trendo

# --- Trend Micro File Security -------------------------------------------------
FILE_SECURITY_API_KEY=

# Región de tu tenant de Vision One:
#   eu-central-1 | us-east-1 | ap-northeast-1 | ap-southeast-1 | ap-southeast-2
FILE_SECURITY_REGION=eu-central-1

# --- Puertos del host ----------------------------------------------------------
BACKEND_PORT=9000
FRONTEND_PORT=80

# --- Backend internals --------------------------------------------------------
UPLOAD_DIR=/data/uploads
